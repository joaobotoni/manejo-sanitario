<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_medicamento_vacinacao_root"
    style="?attr/materialCardViewFilledStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_nome_medicamento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/card_dose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Clostridiose Polivalente" />

        <TextView
            android:id="@+id/text_origem_medicamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_nome_medicamento"
            tools:text="Bezerros · 1 mL/50 kg" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_dose"
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:layout_constraintBottom_toBottomOf="@id/text_origem_medicamento"
            app:layout_constraintEnd_toStartOf="@id/btn_remover_medicamento"
            app:layout_constraintTop_toTopOf="@id/text_nome_medicamento"
            app:shapeAppearance="?attr/shapeAppearanceCornerExtraExtraLarge">

            <TextView
                android:id="@+id/text_dose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="5 mL" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/btn_remover_medicamento"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Remover medicamento"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/close_24px"
            app:layout_constraintBottom_toBottomOf="@id/text_origem_medicamento"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/text_nome_medicamento"
            app:tint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_origem_medicamento" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_aplicado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/checkbox_aplicado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider_item" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_nao_aplicado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/checkbox_nao_aplicado"
            app:layout_constraintBottom_toBottomOf="@id/check_aplicado"
            app:layout_constraintStart_toEndOf="@id/check_aplicado"
            app:layout_constraintTop_toTopOf="@id/check_aplicado" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>